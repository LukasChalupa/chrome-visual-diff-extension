{
  "manifest_version": 3,
  "name": "Visual Diff",
  "version": "1.0",
  "description": "Capture and compare screenshots with opacity and slider.",
  "permissions": [
    "activeTab",
    "storage",
    "unlimitedStorage"
  ],
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "action": {
    "default_title": "Visual Diff",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    },
    "default_popup": "popup.html"
  }
}